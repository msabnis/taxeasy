# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
SESSION_SECRET=your-super-secret-session-key-change-this

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/taxease_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taxease_dev
DB_USER=postgres
DB_PASSWORD=your_db_password

# ─── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_orders,read_products,read_finances,write_script_tags
SHOPIFY_APP_URL=https://your-app-url.railway.app
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# ─── HMRC MTD ─────────────────────────────────────────────────────────────────
HMRC_CLIENT_ID=your_hmrc_client_id
HMRC_CLIENT_SECRET=your_hmrc_client_secret
HMRC_REDIRECT_URI=https://your-app-url.railway.app/auth/hmrc/callback
HMRC_BASE_URL=https://api.service.hmrc.gov.uk
# Use sandbox for development:
# HMRC_BASE_URL=https://test-api.service.hmrc.gov.uk

# ─── GoCardless (Open Banking) ────────────────────────────────────────────────
GOCARDLESS_SECRET_ID=your_gocardless_secret_id
GOCARDLESS_SECRET_KEY=your_gocardless_secret_key
GOCARDLESS_BASE_URL=https://bankaccountdata.gocardless.com/api/v2
# Use sandbox for development:
# GOCARDLESS_BASE_URL=https://ob.sandbox.gocardless.com/api/v2

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRES_IN=7d

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
